{
  "manifest_version": 3,
  "name": "ChatGPT Quick Navigator",
  "version": "0.1.0",
  "description": "为 ChatGPT 长对话生成提问目录，并提供快速搜索与跳转。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/helpers.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
